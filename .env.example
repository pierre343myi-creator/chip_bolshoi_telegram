# ============================================================
# Telegram Bot API
# ============================================================
# Токен бота из @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_token_here
# Порт для webhook-сервера (aiohttp)
WEBHOOK_PORT=8080
# Публичный HTTPS-URL вашей ВМ для регистрации webhook в Telegram API.
# Telegram принимает webhook только по HTTPS и только на портах 443, 80, 88 или 8443,
# поэтому обычно перед aiohttp-сервером ставят reverse-proxy (nginx) с TLS на 443,
# который проксирует запросы на WEBHOOK_PORT (8080).
# Пример: https://your-domain-or-ip/webhook
WEBHOOK_URL=https://your-domain-or-ip/webhook

# ============================================================
# Парсинг
# ============================================================
BOLSHOI_NEWS_URL=https://bolshoi.ru/news/obyavleniya/
PARSE_INTERVAL_HOURS=6
NOTIFY_BEFORE_MINUTES=30

# ============================================================
# PostgreSQL — Yandex Managed Service for PostgreSQL
# Подключение через внутренний IP кластера (внутри VPC)
# SSL обязателен: сертификат — ~/.postgresql/root.crt
# Порт 6432 — pgbouncer (connection pooling)
# ============================================================
DB_HOST=rc1b-xxxxxxxxxxxx.mdb.yandexcloud.net
DB_PORT=6432
DB_NAME=bolshoi_bot
DB_USER=bot_user
DB_PASSWORD=your_db_password
DB_SSL_CA=/home/bolshoi-bot/.postgresql/root.crt
# DATABASE_URL формируется автоматически в config.py:
# postgresql+asyncpg://bot_user:password@host:6432/bolshoi_bot?ssl=verify-full

# ============================================================
# Логирование
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/bolshoi-bot/bot.log
